# Telegram Bot Token (@BotFather dan olinadi)
BOT_TOKEN=your_bot_token_here

# Telegram API (my.telegram.org dan olinadi)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botdb

# Admin ma'lumotlari
ADMIN_TELEGRAM_ID=your_telegram_id_here
ADMIN_PASSWORD=your_admin_password_here
ADMIN_GMAIL=your_gmail@gmail.com
ADMIN_PHONE=+998901234567
ADMIN_USERNAME=your_username

# Gmail SMTP (parol yuborish uchun)
GMAIL_APP_PASSWORD=your_gmail_app_password

# Shifrlash kaliti (sessiyalar uchun) - 32 belgi
ENCRYPTION_KEY=your_32_char_encryption_key_here_!!
